# ============================================================
# AutoPredict AI - Variáveis de Ambiente
# ============================================================
# INSTRUÇÕES:
#   1. Renomeie este arquivo para .env
#   2. Ajuste as senhas (especialmente em produção!)
#   3. NUNCA commite o .env no Git
# ============================================================

# --- MinIO (Data Lake) ---
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin123

# --- PostgreSQL (Banco de Metadados) ---
POSTGRES_USER=autopredict
POSTGRES_PASSWORD=autopredict123
POSTGRES_DB=autopredict

# --- Ollama (Modelo LLM Local) ---
# Opções: llama3.2:1b (rápido), llama3.2:3b (balanço), mistral:7b (melhor qualidade)
# Quanto menor o modelo, mais rápido mas menos preciso
OLLAMA_MODEL=llama3.2:3b
